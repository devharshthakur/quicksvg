{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"dev":       { "cache": false, "persistent": true },
		"build":     { "dependsOn": ["^build"], "outputs": [".svelte-kit/**", "build/**"] },
		"start":     { "dependsOn": ["build"], "cache": false, "persistent": true },
		"format":    {},
		"lint":      {},
		"typecheck":       {},
		"lint-staged":   {},
		"check:outdated": {}
	}
}
